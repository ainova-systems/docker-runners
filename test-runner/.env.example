# E2E Test Runner - Environment Configuration
#
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ==============================================================================
# REQUIRED: GitHub Configuration
# ==============================================================================

# Full URL to your GitHub repository
GITHUB_REPOSITORY_URL=https://github.com/your-org/your-repo

# Runner registration token
# Get it from: Repository -> Settings -> Actions -> Runners -> New self-hosted runner
# NOTE: Tokens expire after 1 hour, generate a new one if needed
GITHUB_RUNNER_TOKEN=your-runner-token-here

# ==============================================================================
# OPTIONAL: Runner Configuration
# ==============================================================================

# Custom runner name (default: test-runner-<hostname>)
# RUNNER_NAME=test-runner-prod

# Runner labels (default: self-hosted,e2e-tests,playwright)
# RUNNER_LABELS=self-hosted,e2e-tests,playwright,linux
